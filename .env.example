# vCenter Provisioner Environment Variables Example
# Copy to .env or .env.ci and fill with real values

# PostgreSQL
POSTGRES_USER=antigravity
POSTGRES_PASSWORD=changeme
POSTGRES_DB=vcenter_provisioner

# Internal API Token (for service-to-service auth)
INTERNAL_API_TOKEN=changeme-internal-token

# vCenter Connection (optional, can use credential-manager)
VCENTER_HOST=
VCENTER_USER=
VCENTER_PASSWORD=
VCENTER_INSECURE=true

# Registry for container images
DOCKER_REGISTRY=antigravity
API_GATEWAY_HASH=local
AUTH_SERVICE_HASH=local
TYPING_SERVICE_HASH=local
VM_ORCHESTRATOR_HASH=local
VCENTER_OPERATIONS_HASH=local
CREDENTIAL_MANAGER_HASH=local
STATS_SERVICE_HASH=local
MONITORING_SERVICE_HASH=local
BACKUP_SERVICE_HASH=local
PROVISIONER_UI_HASH=local
SHARED_SCRIPTS_HASH=local
