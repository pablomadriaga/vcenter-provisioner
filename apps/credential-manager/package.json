{
  "name": "credential-manager",
  "version": "1.0.0",
  "description": "Credential Manager Service - Manage vCenter connections with encrypted credentials",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc && node --loader ts-node/esm src/index.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "vcenter",
    "configuration",
    "credentials",
    "encryption"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/rate-limit": "^11.0.0",
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "knex": "^3.1.0",
    "pg": "^8.12.0",
    "pino": "^10.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.0.10",
    "@types/pg": "^8.11.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
