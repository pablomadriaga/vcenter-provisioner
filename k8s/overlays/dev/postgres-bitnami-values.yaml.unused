fullnameOverride: postgres

image:
  registry: registry-1.docker.io
  repository: bitnami/postgresql
  tag: latest

auth:
  postgresPassword: "password123"
  username: antigravity
  password: ""
  database: vcenter_provisioner

volumePermissions:
  enabled: true

primary:
  persistence:
    storageClass: tanzu-storage
    size: 10Gi
    mountPath: /bitnami/postgresql
  initdbScriptsConfigMap: postgres-init-scripts

containerSecurityContext:
  enabled: true
  runAsNonRoot: true
  runAsUser: 1001
  allowPrivilegeEscalation: false
  capabilities:
    drop:
      - ALL
  seccompProfile:
    type: RuntimeDefault

podSecurityContext:
  enabled: true
  fsGroup: 1001

resources:
  requests:
    memory: "512Mi"
    cpu: "500m"
  limits:
    memory: "1Gi"
    cpu: "1"
