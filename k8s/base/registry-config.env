# Harbor Registry Configuration
# Already installed in cluster (harbor namespace)

# Harbor registry URL (update with your actual Harbor URL)
HARBOR_REGISTRY=harbor.apps.tanzu-cluster
# Or use ClusterIP: 192.101.13.116:5443

# Login to Harbor first:
# kubectl -n harbor get secret harbor-core -o jsonpath="{.data.HARBOR_ADMIN_PASSWORD}" | base64 -d
# docker login -u admin -p <password> harbor.apps.tanzu-cluster

# Image tags for K8s deployment
DOCKER_REGISTRY=harbor.apps.tanzu-cluster/vcenter-provisioner
API_GATEWAY_TAG=v0.2.0
AUTH_SERVICE_TAG=v0.2.0
TYPING_SERVICE_TAG=v0.2.0
VM_ORCHESTRATOR_TAG=v0.2.0
VCENTER_OPERATIONS_TAG=v0.2.0
CREDENTIAL_MANAGER_TAG=v0.2.0
STATS_SERVICE_TAG=v0.2.0
MONITORING_SERVICE_TAG=v0.2.0
BACKUP_SERVICE_TAG=v0.2.0
PROVISIONER_UI_TAG=v0.2.0
SHARED_SCRIPTS_TAG=v0.2.0
